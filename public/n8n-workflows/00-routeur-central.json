{
  "name": "AdamKom - Routeur Central Webhooks",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "bee5d5e1-ce36-42a2-9e82-4662ea996d43",
        "responseMode": "onReceived",
        "responseCode": 200
      },
      "id": "webhook-central",
      "name": "Webhook Central",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [250, 300]
    },
    {
      "parameters": {
        "mode": "rules",
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.body.event }}",
                    "rightValue": "client.signed",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "Client Signé"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.body.event }}",
                    "rightValue": "invoice.created",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "Facture Créée"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.body.event }}",
                    "rightValue": "support.created",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "Support Créé"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.body.event }}",
                    "rightValue": "support.resolved",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "Support Résolu"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.body.event }}",
                    "rightValue": "project.progress",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "Projet 80%"
            }
          ]
        },
        "options": {}
      },
      "id": "switch-event",
      "name": "Router par Event",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [500, 300]
    },
    {
      "parameters": {
        "fromEmail": "contact@adamkom.com",
        "toEmail": "={{ $json.body.client_email }}",
        "subject": "Bienvenue chez AdamKom - {{ $json.body.company_name }}",
        "emailType": "html",
        "html": "<h1>Bienvenue {{ $json.body.company_name }} !</h1><p>Nous sommes ravis de vous compter parmi nos clients.</p><p><strong>Pack choisi :</strong> {{ $json.body.pack_type }}</p><p><strong>Votre référence client :</strong> {{ $json.body.ndi }}</p><p>Notre équipe va maintenant commencer à travailler sur votre projet. Vous recevrez des mises à jour régulières.</p><p>Cordialement,<br>L'équipe AdamKom</p>"
      },
      "id": "email-bienvenue",
      "name": "Email Bienvenue",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2,
      "position": [800, 100]
    },
    {
      "parameters": {
        "fromEmail": "facturation@adamkom.com",
        "toEmail": "={{ $json.body.client_email }}",
        "subject": "Facture {{ $json.body.invoice_number }} - AdamKom",
        "emailType": "html",
        "html": "<h1>Nouvelle Facture</h1><p>Bonjour {{ $json.body.company_name }},</p><p>Votre facture <strong>{{ $json.body.invoice_number }}</strong> est disponible.</p><p><strong>Montant TTC :</strong> {{ $json.body.total_amount }} €</p><p><strong>Date d'échéance :</strong> {{ $json.body.due_date }}</p><p>Cordialement,<br>L'équipe AdamKom</p>"
      },
      "id": "email-facture",
      "name": "Email Facture",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2,
      "position": [800, 250]
    },
    {
      "parameters": {
        "fromEmail": "support@adamkom.com",
        "toEmail": "={{ $json.body.client_email }}",
        "subject": "Ticket {{ $json.body.ticket_number }} reçu - AdamKom Support",
        "emailType": "html",
        "html": "<h1>Votre demande a bien été reçue</h1><p>Bonjour {{ $json.body.company_name }},</p><p>Nous avons bien reçu votre ticket de support :</p><p><strong>Numéro :</strong> {{ $json.body.ticket_number }}</p><p><strong>Objet :</strong> {{ $json.body.subject }}</p><p><strong>Catégorie :</strong> {{ $json.body.category }}</p><p>Notre équipe va traiter votre demande dans les plus brefs délais.</p><p>Cordialement,<br>L'équipe Support AdamKom</p>"
      },
      "id": "email-support-confirm",
      "name": "Email Confirmation Support",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2,
      "position": [800, 400]
    },
    {
      "parameters": {
        "fromEmail": "support@adamkom.com",
        "toEmail": "={{ $json.body.client_email }}",
        "subject": "Ticket {{ $json.body.ticket_number }} résolu - AdamKom",
        "emailType": "html",
        "html": "<h1>Votre ticket a été résolu</h1><p>Bonjour {{ $json.body.company_name }},</p><p>Votre ticket <strong>{{ $json.body.ticket_number }}</strong> a été résolu.</p><p><strong>Objet :</strong> {{ $json.body.subject }}</p><p>Si vous avez d'autres questions, n'hésitez pas à nous contacter.</p><p>Cordialement,<br>L'équipe Support AdamKom</p>"
      },
      "id": "email-support-resolu",
      "name": "Email Ticket Résolu",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2,
      "position": [800, 550]
    },
    {
      "parameters": {
        "fromEmail": "projets@adamkom.com",
        "toEmail": "={{ $json.body.client_email }}",
        "subject": "Votre projet est presque terminé ! - AdamKom",
        "emailType": "html",
        "html": "<h1>Votre projet avance bien !</h1><p>Bonjour {{ $json.body.company_name }},</p><p>Votre projet <strong>{{ $json.body.project_name }}</strong> est maintenant à <strong>{{ $json.body.progress }}%</strong> d'avancement.</p><p>Notre équipe finalise les derniers détails. Vous serez bientôt contacté pour la livraison.</p><p>Cordialement,<br>L'équipe AdamKom</p>"
      },
      "id": "email-progress",
      "name": "Email Progression Projet",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2,
      "position": [800, 700]
    }
  ],
  "connections": {
    "Webhook Central": {
      "main": [
        [
          {
            "node": "Router par Event",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Router par Event": {
      "main": [
        [
          {
            "node": "Email Bienvenue",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Email Facture",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Email Confirmation Support",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Email Ticket Résolu",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Email Progression Projet",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "meta": {
    "description": "Workflow central AdamKom. Les données sont dans $json.body (event, client_email, etc.). Route les events: client.signed, invoice.created, support.created, support.resolved, project.progress"
  }
}
